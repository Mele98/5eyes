APP_NAME=5Eyes WealthArchitekten API
APP_VERSION=1.3.0
APP_ENV=development
# In production, DB_USE_SQLCIPHER=true and DB_KEY must be set.
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO
LOG_MAX_BYTES=2000000
LOG_BACKUP_COUNT=5

DB_PATH=
DB_ECHO=false
DB_USE_SQLCIPHER=false
DB_KEY=
DB_BOOTSTRAP_SCHEMA_ON_STARTUP=true

SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_STRONG_RANDOM_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
LOGIN_RATE_LIMIT_ENABLED=true
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300
LOGIN_LOCKOUT_SECONDS=600

PRICE_SCHEDULER_ENABLED=true
PRICE_SCHEDULER_TIMEZONE=Europe/Zurich
PRICE_SCHEDULER_HOUR=6
PRICE_SCHEDULER_MINUTE=0
PRICE_REFRESH_MAX_ATTEMPTS=2
PRICE_REFRESH_RETRY_DELAY_SECONDS=1.0
PRICE_REFRESH_PRIMARY_PROVIDER=yfinance
PRICE_REFRESH_FALLBACK_PROVIDER=stooq
REFERENCE_DATA_ACTIVE_PROVIDER=local_catalog
ID_MAPPING_ACTIVE_PROVIDER=product_symbol_or_isin
MACRO_ASSUMPTIONS_ACTIVE_PROVIDER=manual_cma
TARGET_MARKET_PRICE_PROVIDER=twelvedata
TARGET_REFERENCE_DATA_PROVIDER=eodhd
TARGET_ID_MAPPING_PROVIDER=openfigi
TARGET_MACRO_CORE_PROVIDER=fred
TARGET_MACRO_EURO_PROVIDER=ecb
TARGET_MACRO_SWISS_PROVIDER=snb
TARGET_ENTERPRISE_REFERENCE_PROVIDER=six
TWELVEDATA_API_KEY=
EODHD_API_KEY=
OPENFIGI_API_KEY=
FRED_API_KEY=
SIX_API_KEY=

# === Multi-Source-Datenpipeline (P1-P20) ===
# Aktiviere die Pipeline mit:
#   PRICE_REFRESH_PRIMARY_PROVIDER=aggregator
# Reihenfolge der Aggregator-Provider (Fallback-Chain, links->rechts):
MARKET_DATA_PROVIDERS=yfinance,stooq,alphavantage
MARKET_DATA_UNHEALTHY_TTL_SECONDS=300
# Alphavantage Free-Tier API Key (500 Calls/Tag, gratis Signup):
#   https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=

# Daily Cache-Purge (taeglich 03:00 lokal):
MARKET_DATA_CACHE_PURGE_ENABLED=true
MARKET_DATA_CACHE_PURGE_HOUR=3
MARKET_DATA_CACHE_PURGE_MINUTE=0

# Weekly Cross-Validation (sonntags 04:00 lokal, default OFF):
MARKET_DATA_VALIDATION_ENABLED=false
MARKET_DATA_VALIDATION_HOUR=4
MARKET_DATA_VALIDATION_MINUTE=0
MARKET_DATA_VALIDATION_DAY_OF_WEEK=sun
# Komma-separierte Symbol-Liste fuer Validation (Yahoo-Style):
MARKET_DATA_VALIDATION_SYMBOLS=
# Alert-Schwelle in Basispunkten (300 = 3% Diff):
MARKET_DATA_VALIDATION_THRESHOLD_BPS=300

# Webhook-Notifier (P22): wenn weekly_validation_job Alerts findet, wird
# JSON an die URL gepostet. Format: { text, alerts[], checked, threshold_bps,
# on_date, generated_at }. Slack-Webhooks fressen 'text' direkt; Discord
# braucht 'content' (Slack-Style aber moeglich via 'wait=true' workaround).
# Default leer -> kein Webhook, nur Logs.
MARKET_DATA_ALERT_WEBHOOK_URL=
MARKET_DATA_ALERT_WEBHOOK_TIMEOUT_SECONDS=5.0

RECENT_LOG_LINES_DEFAULT=120
RECENT_LOG_LINES_MAX=500

# Optimizer mode for goal-based allocation: house_matrix (default, current
# behaviour), iterative (soft-optimization), stochastic (Mulvey/Ziemba-light).
# Spec: docs/planning/2026-05-05-stochastic-optimizer-spec.md
OPTIMIZER_MODE=house_matrix

# Mean-Shift Importance Sampling für Tail-Risk im stochastic Optimizer (Phase 5).
# Default OFF (Phase 5 ist opt-in). Aktivieren mit:
#   MC_IMPORTANCE_SAMPLING_ENABLED=true
# Bringt 5-10x Varianz-Reduktion bei Tail-Statistiken (P(Drawdown > X)).
# Strength typisch 0.3-1.0 (Standard-Deviationen). 0.5 = balanced default.
MC_IMPORTANCE_SAMPLING_ENABLED=false
MC_IMPORTANCE_SAMPLING_STRENGTH=0.5
