# Normalize line endings — checked in as LF, working tree on Windows can stay CRLF
* text=auto eol=lf

# Binary files — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.docx binary
*.xlsx binary
*.zip binary
*.db binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Lock files — keep as-is
package-lock.json -text
