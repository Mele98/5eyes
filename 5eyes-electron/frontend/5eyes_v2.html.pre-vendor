п»ҝ<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>5eyes ГӮВ· WealthArchitekten v4</title>
<style>/* Vendored: system fonts replace Google Fonts (DM Sans + EB Garamond) */
:root{--f-s:system-ui,-apple-system,"Segoe UI",Roboto,"Helvetica Neue",Arial,sans-serif;--f-d:Georgia,"Times New Roman",serif;}
body{font-family:var(--f-s);}
</style>
<script>/* Vendored Chart.js for offline desktop builds */</script>
<script src="vendor/chart.min.js"></script>
<script src="./desktop-api.js"></script>
<style>
/* 5EYES ГӮВ· WEALTHARCHITEKTEN ГӮВ· Navy-Gold */
:root {
  --n9:#09111f; --n8:#0f1e34; --n7:#162844; --n6:#1d3558;
  --n5:#2a4a70; --n4:#3d6491; --n3:#6b94bf; --n2:#b0c8e0; --n1:#dce9f4; --n0:#f0f6fb;
  --g5:#9a7c2e; --g4:#c9a84c; --g3:#dfc070; --g1:#faf3e0; --g0:#fdfaf2;
  --pos:#0e6b41; --pos-lt:#e8f5ef;
  --neg:#8b1e1e; --neg-lt:#fdf0f0;
  --warn:#7a5200; --warn-lt:#fdf5e0;
  --surface:#fff; --bg:#f3f5f8; --bg2:#e8ecf2;
  --b1:rgba(15,30,52,0.08); --b2:rgba(15,30,52,0.15);
  --f-d:'EB Garamond',Georgia,serif;
  --f-s:'DM Sans','Inter',system-ui,sans-serif;
  --r:3px; --r2:5px; --r3:8px;
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;overflow:hidden;font-family:var(--f-s);font-size:13px;line-height:1.5;color:var(--n9);background:var(--bg);}

/* TOPBAR */
.topbar{height:48px;background:var(--n8);border-bottom:2px solid var(--g4);display:flex;align-items:center;position:fixed;top:0;left:0;right:0;z-index:200;}
.logo{width:188px;min-width:188px;height:100%;display:flex;align-items:center;gap:9px;padding:0 16px;border-right:1px solid rgba(255,255,255,0.07);}
.logo-m{width:28px;height:28px;background:var(--g4);border-radius:2px;display:flex;align-items:center;justify-content:center;font-family:var(--f-d);font-size:12px;font-weight:600;color:var(--n8);}
.logo-n{font-family:var(--f-d);font-size:13px;color:#fff;letter-spacing:0.02em;}
.logo-s{font-size:8px;color:var(--g3);letter-spacing:0.14em;text-transform:uppercase;}
.tnav{flex:1;display:flex;align-items:stretch;height:100%;overflow-x:auto;min-width:0;}
.tstep{display:flex;align-items:center;gap:4px;padding:0 8px;cursor:pointer;font-size:10px;color:rgba(255,255,255,0.4);border-bottom:2px solid transparent;white-space:nowrap;transition:all 0.15s;}
.tstep:hover{color:rgba(255,255,255,0.7);}
.tstep.active{color:var(--g3);border-bottom-color:var(--g4);}
.tstep.done{color:rgba(100,200,140,0.85);}
.tstep.done .sn{background:var(--pos);color:#fff;}
.sn{width:16px;height:16px;border-radius:50%;background:rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:600;color:rgba(255,255,255,0.35);flex-shrink:0;}
.tstep.active .sn{background:var(--g4);color:var(--n8);}
.tsep{color:rgba(255,255,255,0.15);font-size:11px;padding:0 1px;}
.tr{display:flex;align-items:center;gap:8px;padding:0 14px;border-left:1px solid rgba(255,255,255,0.07);}
.t-alert{font-size:9px;background:var(--neg);color:#fff;padding:3px 8px;border-radius:2px;font-weight:600;letter-spacing:0.04em;}
.t-btn{background:var(--g4);color:var(--n8);border:none;border-radius:var(--r);font-family:var(--f-s);font-size:11px;font-weight:600;padding:5px 12px;cursor:pointer;}
.t-btn:hover{background:var(--g3);}

/* LAYOUT */
.layout{display:flex;height:calc(100vh - 48px);margin-top:48px;}

/* SIDEBAR */
.sidebar{width:188px;min-width:188px;background:var(--n7);display:flex;flex-direction:column;border-right:1px solid rgba(255,255,255,0.05);}
.sb-hd{padding:11px 12px 8px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid rgba(255,255,255,0.06);}
.sb-lbl{font-size:9px;font-weight:500;letter-spacing:0.13em;text-transform:uppercase;color:rgba(255,255,255,0.28);}
.sb-btn{background:none;border:1px solid rgba(255,255,255,0.12);border-radius:2px;color:rgba(255,255,255,0.3);font-size:9px;padding:2px 7px;cursor:pointer;font-family:var(--f-s);}
.sb-btn:hover{border-color:var(--g4);color:var(--g3);}
.sb-scroll{flex:1;overflow-y:auto;padding:7px 9px;}
.sb-scroll.blurred .client-n,.sb-scroll.blurred .client-m{filter:blur(4px);user-select:none;}
.client{padding:8px 10px;border-radius:var(--r2);cursor:pointer;margin-bottom:4px;border:1px solid transparent;transition:all 0.12s;}
.client:hover{background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.08);}
.client.active{background:rgba(201,168,76,0.12);border-color:rgba(201,168,76,0.35);}
.client-n{font-size:11px;font-weight:500;color:rgba(255,255,255,0.82);margin-bottom:2px;}
.client-m{font-size:9px;color:rgba(255,255,255,0.32);}
.client-tags{display:flex;gap:3px;flex-wrap:wrap;margin-top:5px;}
.ctag{font-size:8px;padding:1px 5px;border-radius:2px;font-weight:500;}
.ct-r{background:rgba(139,30,30,0.4);color:#f5a0a0;}
.ct-g{background:rgba(14,107,65,0.4);color:#7dd4a8;}
.ct-a{background:rgba(122,82,0,0.4);color:#f0c878;}
.ct-b{background:rgba(45,69,143,0.4);color:#9ab4f0;}
.rtag{font-size:10px;padding:4px 9px;border-radius:var(--r2);border:1px solid var(--b2);color:var(--n5);cursor:pointer;transition:all 0.12s;background:var(--surface);user-select:none;display:inline-block;}
.rtag:hover{border-color:var(--n4);color:var(--n8);}
.rtag.rtag-on{background:rgba(14,107,65,0.1);border-color:rgba(14,107,65,0.5);color:var(--pos);font-weight:500;}
.override-badge{display:none;margin-top:6px;padding:4px 8px;background:rgba(201,168,76,0.12);border:1px solid rgba(201,168,76,0.35);border-radius:var(--r);font-size:10px;color:var(--n6);}
input[type=range]#ov-sl{accent-color:var(--n5);}
#ov-disp{color:var(--n8)!important;}
.sb-add{margin:6px 9px 12px;padding:8px;text-align:center;border:1px dashed rgba(201,168,76,0.3);border-radius:var(--r2);font-size:10px;color:rgba(201,168,76,0.55);cursor:pointer;background:none;font-family:var(--f-s);width:calc(100% - 18px);transition:all 0.12s;}
.sb-add:hover{border-color:var(--g4);color:var(--g4);}

/* CONTENT */
.content{flex:1;overflow-y:auto;background:var(--bg);}
.page{display:none;}
.page.active{display:block;}

/* PAGE HEADER */
.ph{background:var(--surface);border-bottom:1px solid var(--b1);padding:14px 24px;display:flex;justify-content:space-between;align-items:center;}
.ph-t{font-family:var(--f-d);font-size:21px;font-weight:500;color:var(--n8);margin-bottom:2px;}
.ph-s{font-size:10px;color:var(--n4);}
.ph-r{display:flex;gap:7px;}
.pad{padding:16px 24px;}
.mb{margin-bottom:12px;}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:12px;}

/* BUTTONS */
.btn{background:none;border:1px solid var(--b2);border-radius:var(--r);font-family:var(--f-s);font-size:11px;color:var(--n6);padding:6px 13px;cursor:pointer;transition:all 0.12s;}
.btn:hover{border-color:var(--n4);color:var(--n8);}
.btn-p{background:var(--n6);color:#fff;border:none;border-radius:var(--r);font-family:var(--f-s);font-size:11px;font-weight:500;padding:6px 13px;cursor:pointer;}
.btn-p:hover{background:var(--n5);}
.btn-g{background:var(--g4);color:var(--n8);border:none;border-radius:var(--r);font-family:var(--f-s);font-size:11px;font-weight:600;padding:6px 13px;cursor:pointer;}
.btn-g:hover{background:var(--g3);}
.btn-sm{padding:4px 9px;font-size:10px;}
.btn-ico{background:none;border:none;cursor:pointer;color:var(--n3);padding:2px 4px;font-size:11px;border-radius:2px;}
.btn-ico:hover{background:var(--bg2);color:var(--neg);}
.btn-ico.e:hover{color:var(--n5);}

/* STRIP */
.strip{padding:9px 24px;display:flex;align-items:center;justify-content:space-between;gap:14px;border-bottom:1px solid var(--b1);}
.strip-e{background:var(--neg-lt);}
.strip-w{background:var(--warn-lt);}
.st{font-size:11px;font-weight:600;color:var(--n8);margin-bottom:1px;}
.ss{font-size:10px;color:var(--n5);}

/* CARD */
.card{background:var(--surface);border:1px solid var(--b1);border-radius:var(--r3);overflow:hidden;margin-bottom:12px;}
.card:last-child{margin-bottom:0;}
.chd{padding:10px 16px 8px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--b1);background:var(--n0);}
.cht{font-size:10px;font-weight:600;color:var(--n7);letter-spacing:0.05em;text-transform:uppercase;}
.chr{display:flex;gap:6px;align-items:center;}
.cbody{padding:12px 16px;}

/* KPI */
.kpir{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:12px;}
.kpi{background:var(--surface);border:1px solid var(--b1);border-radius:var(--r2);padding:12px 14px;cursor:pointer;transition:all 0.12s;border-top:2px solid transparent;}
.kpi:hover{border-top-color:var(--g4);box-shadow:0 2px 10px rgba(15,30,52,0.08);}
.kl{font-size:9px;font-weight:500;letter-spacing:0.09em;text-transform:uppercase;color:var(--n4);margin-bottom:5px;}
.kv{font-family:var(--f-d);font-size:18px;color:var(--n8);margin-bottom:2px;}
.ks{font-size:10px;color:var(--n4);}
.g{color:var(--pos);font-weight:500;}
.r{color:var(--neg);font-weight:500;}
.a{color:var(--warn);font-weight:500;}

/* TAGS */
.tag{font-size:9px;font-weight:500;padding:2px 6px;border-radius:2px;white-space:nowrap;display:inline-block;}
.tg{background:var(--pos-lt);color:var(--pos);}
.tr2{background:var(--neg-lt);color:var(--neg);}
.ta{background:var(--warn-lt);color:var(--warn);}
.tn{background:var(--bg2);color:var(--n5);}
.tb{background:var(--n1);color:var(--n6);}

/* PS GRID */
.psg{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.psk{font-size:10px;color:var(--n4);margin-bottom:1px;}
.psv{font-size:11px;font-weight:500;color:var(--n8);}

/* WEALTH ROWS */
.wr{display:flex;align-items:center;padding:6px 0;border-bottom:1px solid var(--b1);}
.wr:last-child{border-bottom:none;}
.wn{flex:1;}
.wna{font-size:11px;font-weight:500;color:var(--n8);}
.wnd{font-size:9px;color:var(--n4);}
.wa{font-size:11px;font-weight:500;min-width:110px;text-align:right;}
.wt{min-width:65px;text-align:right;}
.wtotal{display:flex;justify-content:space-between;align-items:center;padding:7px 0 0;border-top:1px solid var(--b2);margin-top:3px;}

/* CASHFLOW */
.cf-sec{font-size:9px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--n4);padding:7px 0 3px;border-bottom:1px solid var(--b1);margin-bottom:3px;}
.cf-row{display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid var(--b1);}
.cf-row:last-of-type{border-bottom:none;}
.cfi{width:20px;height:20px;border-radius:3px;display:flex;align-items:center;justify-content:center;font-size:10px;flex-shrink:0;}
.cf-i{flex:1;}
.cf-na{font-size:11px;font-weight:500;color:var(--n8);}
.cf-d{font-size:9px;color:var(--n4);}
.cf-a{font-size:11px;font-weight:500;min-width:90px;text-align:right;}
.ci{color:var(--pos);}
.co{color:var(--neg);}
.cft{display:flex;justify-content:space-between;align-items:center;padding:8px 0 0;border-top:2px solid var(--b2);margin-top:3px;}

/* BUDGET */
.bgsec{margin-bottom:8px;}
.bghd{font-size:9px;font-weight:600;letter-spacing:0.07em;text-transform:uppercase;color:var(--g5);padding:5px 0 3px;border-bottom:1px solid var(--b1);}
.bgrow{display:flex;align-items:center;gap:5px;padding:4px 0;border-bottom:1px solid var(--b1);}
.bgrow:last-child{border-bottom:none;}
.bgn{flex:1;font-size:11px;color:var(--n7);}
.bginp{width:85px;text-align:right;border:1px solid var(--b1);border-radius:2px;padding:2px 6px;font-family:var(--f-s);font-size:11px;color:var(--n8);background:var(--bg);outline:none;}
.bginp:focus{border-color:var(--g4);}
.bgy{font-size:10px;color:var(--n4);min-width:72px;text-align:right;}

/* GOALS */
.goal{display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid var(--b1);cursor:grab;}
.goal:last-child{border-bottom:none;}
.pd{width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:600;flex-shrink:0;}
.p1{background:var(--n8);color:#fff;}
.p2{background:var(--n5);color:#fff;}
.p3{background:var(--n2);color:var(--n7);}
.gi{flex:1;}
.gn{font-size:11px;font-weight:500;color:var(--n8);}
.gd{font-size:9px;color:var(--n4);}
.gbw{width:68px;}
.gp{font-size:9px;color:var(--n4);text-align:right;margin-bottom:2px;}
.gb{height:3px;background:var(--b1);border-radius:2px;overflow:hidden;}
.gf{height:100%;border-radius:2px;}
.fg{background:var(--pos);}
.fa{background:var(--g4);}
.fr{background:var(--neg);}

/* RISK QUESTIONNAIRE ГўвӮ¬вҖқ 3 TABS (new) */
.risk-tabs{display:flex;border-bottom:2px solid var(--b1);margin-bottom:12px;}
.rtab{padding:8px 14px;font-size:11px;color:var(--n4);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;transition:all 0.12s;}
.rtab:hover{color:var(--n7);}
.rtab.active{color:var(--n8);border-bottom-color:var(--g4);font-weight:500;}
.rpanel{display:none;}
.rpanel.active{display:block;}
.qsec{margin-bottom:14px;}
.ql{font-size:11px;font-weight:500;color:var(--n8);margin-bottom:6px;display:flex;align-items:flex-start;gap:7px;}
.qnum{display:inline-flex;align-items:center;justify-content:center;width:17px;height:17px;background:var(--n7);color:#fff;border-radius:50%;font-size:9px;font-weight:600;flex-shrink:0;}
.qopts{display:flex;flex-direction:column;gap:4px;padding-left:24px;}
.qopt{display:flex;align-items:flex-start;gap:6px;padding:5px 8px;border:1px solid var(--b1);border-radius:var(--r);cursor:pointer;transition:all 0.12s;}
.qopt:hover{border-color:var(--g4);}
.qopt.sel{border-color:var(--n6);background:var(--n0);}
.qrad{width:12px;height:12px;border:2px solid var(--b2);border-radius:50%;flex-shrink:0;margin-top:1px;position:relative;}
.qopt.sel .qrad{border-color:var(--n6);background:var(--n6);}
.qopt.sel .qrad::after{content:'';position:absolute;width:4px;height:4px;background:#fff;border-radius:50%;top:50%;left:50%;transform:translate(-50%,-50%);}
.qtxt{font-size:11px;color:var(--n7);}
.qcbs{display:grid;grid-template-columns:1fr 1fr;gap:3px;padding-left:24px;}
.qcb{display:flex;align-items:center;gap:5px;padding:5px 8px;border:1px solid var(--b1);border-radius:var(--r);cursor:pointer;font-size:10px;color:var(--n7);transition:all 0.12s;}
.qcb:hover{border-color:var(--g4);}
.qcb.sel{border-color:var(--n6);background:var(--n0);}
.qbox{width:11px;height:11px;border:2px solid var(--b2);border-radius:2px;position:relative;flex-shrink:0;}
.qcb.sel .qbox{background:var(--n6);border-color:var(--n6);}
.qcb.sel .qbox::after{content:'ГўЕ“вҖң';position:absolute;color:#fff;font-size:8px;top:50%;left:50%;transform:translate(-50%,-50%);}
.qinp{width:100%;padding:5px 8px;border:1px solid var(--b1);border-radius:var(--r);font-family:var(--f-s);font-size:11px;color:var(--n8);background:var(--bg);outline:none;}
.qinp:focus{border-color:var(--g4);}
.resbox{background:var(--g0);border:1px solid rgba(201,168,76,0.3);border-left:3px solid var(--g4);border-radius:var(--r2);padding:11px 14px;}
.res-t{font-size:9px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:var(--g5);margin-bottom:3px;}
.res-p{font-family:var(--f-d);font-size:20px;color:var(--n8);margin-bottom:3px;}
.res-d{font-size:10px;color:var(--n6);line-height:1.6;}

/* RISK DIMS */
.rdg{display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px;margin-bottom:10px;}
.rdim{background:var(--bg);border:1px solid var(--b1);border-radius:var(--r2);padding:9px 11px;}
.rdl{font-size:9px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;color:var(--n4);margin-bottom:5px;}
.rsc{display:flex;gap:2px;margin-bottom:4px;}
.rs{flex:1;height:4px;border-radius:2px;background:var(--b1);}
.rs.on{background:var(--g4);}
.rval{font-family:var(--f-d);font-size:15px;color:var(--n8);margin-bottom:1px;}
.rsub{font-size:9px;color:var(--n4);line-height:1.4;}

/* QUOTEN TABLE */
.qt-hdr{display:grid;grid-template-columns:8px 1fr 42px 64px 64px 64px;gap:0;padding-bottom:5px;border-bottom:2px solid var(--b2);margin-bottom:2px;}
.qt-row{display:grid;grid-template-columns:8px 1fr 42px 64px 64px 64px;gap:0;align-items:center;padding:5px 0;border-bottom:1px solid var(--b1);}
.qt-row:last-child{border-bottom:none;}
.qt-dot{width:7px;height:7px;border-radius:50%;}
.qt-n{font-size:11px;color:var(--n7);padding-left:7px;}
.qt-ist{font-size:11px;color:var(--n4);text-align:right;}
.qt-inp{width:56px;text-align:right;border:1px solid var(--b1);border-radius:2px;padding:3px 5px;font-family:var(--f-s);font-size:11px;color:var(--n8);background:var(--bg);outline:none;}
.qt-inp:focus{border-color:var(--g4);}

/* FP VARIANT */
.fpv{border:1px solid var(--b1);border-radius:var(--r2);padding:10px 12px;margin-bottom:7px;cursor:pointer;transition:all 0.12s;}
.fpv:last-child{margin-bottom:0;}
.fpv:hover{border-color:var(--g4);}
.fpv.active{border-color:var(--n6);background:var(--n0);border-left:3px solid var(--g4);}
.fpv-hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;}
.fpv-t{font-size:11px;font-weight:500;color:var(--n8);}
.fpv-g{display:grid;grid-template-columns:1fr 1fr;gap:4px;}
.fpv-k{font-size:9px;color:var(--n4);}
.fpv-v{font-size:11px;font-weight:500;color:var(--n8);}

/* DONUT */
.donut-wrap{position:relative;width:150px;height:150px;margin:0 auto;}
.dc{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;pointer-events:none;}
.dcv{font-family:var(--f-d);font-size:14px;color:var(--n8);text-align:center;line-height:1.2;}
.dcl{font-size:8px;color:var(--n4);letter-spacing:0.05em;text-transform:uppercase;}

/* ALLOC TABLE */
.ar{display:grid;grid-template-columns:8px 1fr 50px 68px 50px 68px 52px;gap:0;align-items:center;padding:6px 0;border-bottom:1px solid var(--b1);}
.ar:last-child{border-bottom:none;}
.ad{width:7px;height:7px;border-radius:50%;}
.an{font-size:11px;color:var(--n7);padding-left:6px;}
.av{font-size:11px;text-align:right;}
.as{font-size:11px;color:var(--n4);text-align:right;}
.adl{font-size:10px;font-weight:500;padding:1px 4px;border-radius:2px;text-align:right;}
.dn{background:var(--neg-lt);color:var(--neg);}
.dok{background:var(--bg2);color:var(--n4);}
.dp{background:var(--pos-lt);color:var(--pos);}

/* PORTFOLIO */
.ps{margin-bottom:5px;}
.psh{background:var(--n7);padding:7px 14px;display:flex;justify-content:space-between;align-items:center;border-radius:var(--r2) var(--r2) 0 0;}
.psn{font-size:10px;font-weight:600;color:#fff;letter-spacing:0.05em;text-transform:uppercase;}
.psr{display:flex;gap:10px;}
.psp{font-size:10px;font-weight:500;color:var(--g3);}
.psc{font-size:10px;color:rgba(255,255,255,0.4);}
.psubh{background:var(--bg2);padding:5px 14px;display:flex;justify-content:space-between;border-bottom:1px solid var(--b1);}
.pcols{display:grid;grid-template-columns:92px 1fr 72px 56px 60px 56px 66px 42px;gap:0;padding:4px 14px;background:var(--n0);border-bottom:1px solid var(--b1);}
.pch{font-size:9px;font-weight:500;letter-spacing:0.05em;text-transform:uppercase;color:var(--n4);}
.prow{display:grid;grid-template-columns:92px 1fr 72px 56px 60px 56px 66px 42px;gap:0;align-items:center;padding:6px 14px;border-bottom:1px solid var(--b1);}
.prow:hover{background:var(--n0);}
.pisin{font-size:9px;color:var(--n4);font-family:monospace;}
.pname{font-size:11px;color:var(--n8);}
.pdet{font-size:9px;color:var(--n4);}
.pval{font-size:11px;text-align:right;}
.pperf{font-size:10px;font-weight:500;text-align:right;}
.ptot{display:flex;justify-content:space-between;padding:6px 14px;background:var(--n0);border-top:1px solid var(--b2);border-radius:0 0 var(--r2) var(--r2);}

/* TRIG / LOG */
.trig{border:1px solid var(--b1);border-radius:var(--r2);padding:9px 12px;margin-bottom:6px;background:var(--surface);}
.trig:last-child{margin-bottom:0;}
.trig.al{border-color:rgba(139,30,30,0.25);background:var(--neg-lt);}
.trigh{display:flex;justify-content:space-between;align-items:center;margin-bottom:3px;}
.trign{font-size:11px;font-weight:500;color:var(--n8);}
.trigd{font-size:10px;color:var(--n6);line-height:1.4;}
.logi{padding:8px 0;border-bottom:1px solid var(--b1);}
.logi:last-child{border-bottom:none;}
.logh{display:flex;justify-content:space-between;margin-bottom:3px;}
.logt{font-size:11px;font-weight:500;color:var(--n8);}
.logm{display:flex;gap:5px;align-items:center;}
.logd{font-size:10px;color:var(--n4);}
.logdesc{font-size:10px;color:var(--n6);line-height:1.5;}

/* CHARTS */
.chart{height:160px;position:relative;}
.chart-lg{height:210px;position:relative;}

/* MODAL */
.overlay{position:fixed;inset:0;background:rgba(9,17,31,0.55);display:none;align-items:center;justify-content:center;z-index:500;}
.overlay.open{display:flex;}
.modal{background:var(--surface);border-radius:var(--r3);width:500px;max-height:86vh;overflow-y:auto;box-shadow:0 12px 50px rgba(0,0,0,0.25);border-top:3px solid var(--g4);}
.modal-lg{width:660px;}
.mhd{padding:17px 22px 11px;border-bottom:1px solid var(--b1);display:flex;justify-content:space-between;align-items:center;}
.mtitle{font-family:var(--f-d);font-size:18px;color:var(--n8);}
.mx{background:none;border:none;cursor:pointer;font-size:16px;color:var(--n4);}
.mx:hover{color:var(--n8);}
.mbody{padding:17px 22px;}
.mfooter{padding:11px 22px;border-top:1px solid var(--b1);display:flex;justify-content:flex-end;gap:7px;}
.fs{font-size:9px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--g5);margin-bottom:7px;margin-top:3px;}
.frow{display:flex;gap:9px;margin-bottom:9px;}
.fg{flex:1;}
.fl{font-size:10px;font-weight:500;color:var(--n6);margin-bottom:3px;display:block;}
.fi{width:100%;padding:6px 9px;border:1px solid var(--b2);border-radius:var(--r);font-family:var(--f-s);font-size:11px;color:var(--n8);background:var(--bg);outline:none;}
.fi:focus{border-color:var(--g4);background:#fff;}
.fsel{width:100%;padding:6px 9px;border:1px solid var(--b2);border-radius:var(--r);font-family:var(--f-s);font-size:11px;color:var(--n8);background:var(--bg);outline:none;cursor:pointer;}
.fta{width:100%;padding:6px 9px;border:1px solid var(--b2);border-radius:var(--r);font-family:var(--f-s);font-size:11px;color:var(--n8);background:var(--bg);outline:none;resize:vertical;}
.cnav{background:var(--surface);border-top:1px solid var(--b1);padding:10px 24px;display:flex;justify-content:space-between;align-items:center;position:sticky;bottom:0;}
.cni{font-size:10px;color:var(--n4);}
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-thumb{background:var(--n2);border-radius:2px;}

/* ГўвҖқвӮ¬ГўвҖқвӮ¬ V4 COMPATIBILITY ALIASES ГўвҖқвӮ¬ГўвҖқвӮ¬ */
.sb-list{flex:1;overflow-y:auto;padding:7px 9px;}
.sb-list.blurred .cn,.sb-list.blurred .cm{filter:blur(4px);user-select:none;}
.cn{font-size:11px;font-weight:500;color:rgba(255,255,255,0.82);margin-bottom:2px;}
.cm{font-size:9px;color:rgba(255,255,255,0.32);}
.ctags{display:flex;gap:3px;flex-wrap:wrap;margin-top:5px;}
/* Cashflow aliases */
.cfn{flex:1;}
.cfna{font-size:11px;font-weight:500;color:var(--n8);}
.cfnd{font-size:9px;color:var(--n4);}
.cfa{font-size:11px;font-weight:500;min-width:90px;text-align:right;}
/* Row aliases */
.ri{flex:1;}
.rn{font-size:11px;font-weight:500;color:var(--n8);}
.rd{font-size:10px;color:var(--n4);}
/* Color aliases */
.g{color:var(--pos);font-weight:500;}
.a{color:var(--warn);font-weight:500;}
/* Button alias */
.e{}
/* Portfolio sub-header */
.psubn{font-size:10px;color:var(--n6);font-weight:500;}
/* Indexierung */
.idx-col{display:none;align-items:center;gap:3px;min-width:70px;}
.idx-inp{width:42px;text-align:right;border:1px solid var(--b1);border-radius:2px;padding:2px 4px;font-family:var(--f-s);font-size:10px;background:var(--bg);outline:none;}
.idx-inp:focus{border-color:var(--g4);}

/* v4 single-letter utility classes */
.g{color:var(--pos);font-weight:500;}
.r{color:var(--neg);font-weight:500;}
.a{color:var(--warn);font-weight:500;}
.e{}

/* v4 cashflow classes */
.cfn{flex:1;} .cfna{font-size:11px;font-weight:500;color:var(--n8);}
.cfnd{font-size:9px;color:var(--n4);} .cfa{font-size:11px;font-weight:500;min-width:90px;text-align:right;}
.ci{color:var(--pos);} .co{color:var(--neg);}
/* v4 sidebar classes */
.sb-list{flex:1;overflow-y:auto;padding:7px 9px;}
.sb-list.blurred .cn,.sb-list.blurred .cm{filter:blur(4px);user-select:none;}
.cn{font-size:11px;font-weight:500;color:rgba(255,255,255,0.82);margin-bottom:2px;}
.cm{font-size:9px;color:rgba(255,255,255,0.32);}
.ctags{display:flex;gap:3px;flex-wrap:wrap;margin-top:5px;}
/* v4 row classes */
.ri{flex:1;} .rn{font-size:11px;font-weight:500;color:var(--n8);}
.rd{font-size:10px;color:var(--n4);}
/* v4 portfolio */
.psubn{font-size:10px;color:var(--n6);font-weight:500;}
/* indexierung */
.idx-col{display:none;align-items:center;gap:3px;min-width:70px;}
.idx-inp{width:42px;text-align:right;border:1px solid var(--b1);border-radius:2px;padding:2px 4px;font-family:var(--f-s);font-size:10px;background:var(--bg);outline:none;}
.idx-inp:focus{border-color:var(--g4);}

@media print {
  .topbar,.sidebar,.cnav,.ph-r,.chr,.btn,.btn-p,.btn-g,.btn-ico,.overlay{display:none!important;}
  .layout{margin-top:0!important;height:auto!important;display:block!important;}
  .content{overflow:visible!important;}
  .page{display:none!important;}
  .page.active{display:block!important;}
  body{background:#fff;}
  .card{break-inside:avoid;border:1px solid #ccc;}
  @page{margin:15mm;size:A4;}
}

/* buildQT classes */
.qtr{display:grid;grid-template-columns:8px 1fr 42px 64px 64px 64px;gap:0;align-items:center;padding:5px 0;border-bottom:1px solid var(--b1);}
.qtr:last-child{border-bottom:none;}
.qtd{width:7px;height:7px;border-radius:50%;}
.qtn{font-size:11px;color:var(--n7);padding-left:7px;}
.qti{font-size:11px;color:var(--n4);text-align:right;}
.qtinp{width:56px;text-align:right;border:1px solid var(--b1);border-radius:2px;padding:3px 5px;font-family:var(--f-s);font-size:11px;color:var(--n8);background:var(--bg);outline:none;}
.qtinp:focus{border-color:var(--g4);}
/* dcv dcl for donut center */
.dcv{font-family:var(--f-d);font-size:14px;color:var(--n8);text-align:center;line-height:1.2;}
.dcl{font-size:8px;color:var(--n4);letter-spacing:0.05em;text-transform:uppercase;}
</style>
</head>
<body>
<!-- ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ LOGIN / BOOTSTRAP OVERLAY ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ -->
<div id="login-overlay" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(10,20,35,0.92);z-index:9999;align-items:center;justify-content:center;flex-direction:column;gap:16px;">
  <div style="background:var(--card);border:1px solid var(--border);border-radius:12px;padding:40px 48px;min-width:360px;max-width:460px;box-shadow:0 18px 40px rgba(0,0,0,0.35);">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:18px;">
      <div style="width:36px;height:36px;background:var(--acc);border-radius:8px;display:flex;align-items:center;justify-content:center;font-weight:700;color:#fff;font-size:14px;">5e</div>
      <div>
        <div style="font-size:15px;font-weight:600;color:var(--txt)">WealthArchitekten</div>
        <div style="font-size:10px;color:var(--g3);letter-spacing:0.1em;text-transform:uppercase;">Advisory OS</div>
      </div>
    </div>
    <div id="login-panel">
      <div style="font-size:12px;color:var(--g3);line-height:1.6;margin-bottom:16px;">Melde dich mit deinem lokalen Benutzerkonto an. Tokens bleiben nur lokal auf diesem GerГғВӨt gespeichert.</div>
      <div style="margin-bottom:14px;">
        <label style="font-size:11px;color:var(--g3);display:block;margin-bottom:4px;">Benutzername</label>
        <input id="login-username" type="text" autocomplete="username"
          style="width:100%;box-sizing:border-box;background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:9px 12px;color:var(--txt);font-size:13px;outline:none;"
          onkeydown="if(event.key==='Enter')document.getElementById('login-password').focus()"
          placeholder="berater@firma.ch" />
      </div>
      <div style="margin-bottom:20px;">
        <label style="font-size:11px;color:var(--g3);display:block;margin-bottom:4px;">Passwort</label>
        <input id="login-password" type="password" autocomplete="current-password"
          style="width:100%;box-sizing:border-box;background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:9px 12px;color:var(--txt);font-size:13px;outline:none;"
          onkeydown="if(event.key==='Enter')doLogin()" />
      </div>
      <div id="login-error" style="color:#e05a5a;font-size:11px;min-height:16px;margin-bottom:10px;"></div>
      <button id="btn-login-submit" onclick="doLogin()"
        style="width:100%;background:var(--acc);color:#fff;border:none;border-radius:6px;padding:10px;font-size:13px;font-weight:600;cursor:pointer;">
        Anmelden
      </button>
      <div id="login-bootstrap-hint" style="display:none;margin-top:14px;font-size:11px;color:var(--g3);line-height:1.6;">
        Die Datenbank ist noch nicht initialisiert. <a href="#" onclick="showBootstrap();return false;" style="color:var(--acc);text-decoration:none;">Ersten Admin anlegen</a>
      </div>
    </div>

    <div id="bootstrap-panel" style="display:none;">
      <div style="font-size:12px;color:var(--g3);line-height:1.6;margin-bottom:16px;">Ersteinrichtung: Lege den ersten lokalen Admin-Benutzer an. Dieser Schritt ist nur verfГғВјgbar, solange noch kein Benutzer existiert.</div>
      <div style="display:grid;gap:12px;">
        <div>
          <label style="font-size:11px;color:var(--g3);display:block;margin-bottom:4px;">VollstГғВӨndiger Name</label>
          <input id="bootstrap-full-name" type="text" autocomplete="name" style="width:100%;box-sizing:border-box;background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:9px 12px;color:var(--txt);font-size:13px;outline:none;" placeholder="Max Muster" />
        </div>
        <div>
          <label style="font-size:11px;color:var(--g3);display:block;margin-bottom:4px;">Benutzername</label>
          <input id="bootstrap-username" type="text" autocomplete="username" style="width:100%;box-sizing:border-box;background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:9px 12px;color:var(--txt);font-size:13px;outline:none;" placeholder="admin" />
        </div>
        <div>
          <label style="font-size:11px;color:var(--g3);display:block;margin-bottom:4px;">E-Mail (optional)</label>
          <input id="bootstrap-email" type="email" autocomplete="email" style="width:100%;box-sizing:border-box;background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:9px 12px;color:var(--txt);font-size:13px;outline:none;" placeholder="admin@firma.ch" />
        </div>
        <div>
          <label style="font-size:11px;color:var(--g3);display:block;margin-bottom:4px;">Passwort</label>
          <input id="bootstrap-password" type="password" autocomplete="new-password" style="width:100%;box-sizing:border-box;background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:9px 12px;color:var(--txt);font-size:13px;outline:none;" placeholder="Mindestens 10 Zeichen" />
        </div>
        <div>
          <label style="font-size:11px;color:var(--g3);display:block;margin-bottom:4px;">Passwort bestГғВӨtigen</label>
          <input id="bootstrap-password-confirm" type="password" autocomplete="new-password" style="width:100%;box-sizing:border-box;background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:9px 12px;color:var(--txt);font-size:13px;outline:none;" onkeydown="if(event.key==='Enter')doBootstrapAdmin()" />
        </div>
      </div>
      <div id="bootstrap-error" style="color:#e05a5a;font-size:11px;min-height:16px;margin-top:12px;margin-bottom:10px;"></div>
      <button id="btn-bootstrap-submit" onclick="doBootstrapAdmin()"
        style="width:100%;background:var(--acc);color:#fff;border:none;border-radius:6px;padding:10px;font-size:13px;font-weight:600;cursor:pointer;">
        Admin anlegen
      </button>
      <div style="margin-top:14px;font-size:11px;color:var(--g3);line-height:1.6;">
        Bereits eingerichtet? <a href="#" onclick="showLogin();return false;" style="color:var(--acc);text-decoration:none;">Zur Anmeldung</a>
      </div>
    </div>
  </div>
</div>
<!-- ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ -->



<header class="topbar">
  <div class="logo">
    <div class="logo-m">5e</div>
    <div><div class="logo-n">WealthArchitekten</div><div class="logo-s">Advisory OS</div></div>
  </div>
  <nav class="tnav">
    <div class="tstep done" onclick="go('sd',this,0)"><div class="sn">ГўЕ“вҖң</div>Stammdaten</div>
    <div class="tsep">ГўвӮ¬Вә</div>
    <div class="tstep done" onclick="go('rp',this,1)"><div class="sn">ГўЕ“вҖң</div>Risikoprofil</div>
    <div class="tsep">ГўвӮ¬Вә</div>
    <div class="tstep active" onclick="go('ub',this,2)"><div class="sn">3</div>ГғЕ“bersicht &amp; Ziele</div>
    <div class="tsep">ГўвӮ¬Вә</div>
    <div class="tstep" onclick="go('al',this,3)"><div class="sn">4</div>Asset Allokation</div>
    <div class="tsep">ГўвӮ¬Вә</div>
    <div class="tstep" onclick="go('po',this,4)"><div class="sn">5</div>Portfolio &amp; Titel</div>
    <div class="tsep">ГўвӮ¬Вә</div>
    <div class="tstep" onclick="go('rv',this,5)"><div class="sn">6</div>Review Policy</div>
    <div class="tsep">ГўвӮ¬Вә</div>
    <div class="tstep" onclick="go('sr',this,6)"><div class="sn">7</div>Zusammenfassung</div>
  </nav>
  <div class="tr">
    <span class="t-alert" id="trigger-count">2 Trigger</span>
    <span id="current-user-label" style="font-size:11px;color:var(--g3);margin-right:4px"></span>
    <button class="t-btn" onclick="om('m-nc')">+ Mandat</button>
    <button class="t-btn" id="btn-admin-open" onclick="om('m-admin')" style="display:none;background:var(--g2);color:var(--g5)" title="System-Administration">ГўЕЎв„ў</button>
    <button class="t-btn" id="btn-logout" onclick="doLogout()" style="display:none;background:var(--g2);color:var(--g5)">Abmelden</button>
  </div>
</header>

<div class="layout">
  <aside class="sidebar">
    <div class="sb-hd">
      <span class="sb-lbl">Mandate <span id="alert-count" style="background:var(--neg);color:#fff;border-radius:2px;padding:1px 5px;font-size:8px;margin-left:4px">2</span></span>
      <button class="sb-btn" id="pb" onclick="toggleP()">Ausblenden</button>
    </div>
    <div class="sb-scroll" id="sbl">
      <div class="client" data-pid="HH-001" onclick="selC(this);loadPersona('HH-001')">
        <div class="cn">Lukas Meier</div>
        <div class="cm">CHF 153k ГӮВ· ZH</div>
        <div class="ctags"><span class="ctag ct-g">Moderat</span><span class="ctag ct-b">Wachstum</span></div>
      </div>
      <div class="client" data-pid="HH-002" onclick="selC(this);loadPersona('HH-002')">
        <div class="cn">Sarah Keller</div>
        <div class="cm">CHF 400k ГӮВ· BS</div>
        <div class="ctags"><span class="ctag ct-g">Moderat</span><span class="ctag ct-b">Wachstum</span></div>
      </div>
