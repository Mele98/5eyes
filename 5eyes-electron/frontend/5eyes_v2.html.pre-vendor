    <!-- PAGE: RISIKOPROFIL -->
    <div id="page-rp" class="page">
      <div class="ph"><div><div class="ph-t">Risikoprofilierung (FINMA W305.02)</div><div class="ph-s">RisikofГғВӨhigkeit ГӮВ· Risikobereitschaft ГӮВ· Soll-Quoten</div></div><div class="ph-r"><button class="btn" onclick="om('m-rp-print')">PDF</button><button class="btn-p" onclick="go('ub')">ГғЕ“bersicht &amp; Ziele ГўвҖ вҖҷ</button></div></div>
      <div class="pad">
        <div class="g2">
                    <div>
            <div class="card">
              <div class="chd">
                <span class="cht">Fragebogen FINMA W305.02</span>
                <span style="font-size:9px;color:var(--n4)">Antworten direkt anklicken</span>
              </div>
              <div class="cbody" style="padding-top:0">
                <!-- 3 TABS -->
                <div class="risk-tabs">
                  <div class="rtab active" onclick="switchRTab(this,'r-ke')">1 ГӮВ· Kenntnisse &amp; Erfahrungen</div>
                  <div class="rtab" onclick="switchRTab(this,'r-rf')">2 ГӮВ· RisikofГғВӨhigkeit</div>
                  <div class="rtab" onclick="switchRTab(this,'r-rb')">3 ГӮВ· Risikobereitschaft</div>
                </div>

                <!-- TAB 1: KENNTNISSE & ERFAHRUNGEN -->
                <div id="r-ke" class="rpanel active">
                  <div class="qsec">
                    <div class="ql"><span class="qnum">1</span><span>Anlageinstrumente eingesetzt? <em style="font-size:9px;color:var(--n4)">(Mehrfachauswahl)</em></span></div>
                    <div class="qcbs">
                      <div class="qcb sel" onclick="this.classList.toggle('sel')"><div class="qbox"></div>Geldmarkt / ETF</div>
                      <div class="qcb sel" onclick="this.classList.toggle('sel')"><div class="qbox"></div>Obligationen</div>
                      <div class="qcb sel" onclick="this.classList.toggle('sel')"><div class="qbox"></div>Aktien</div>
                      <div class="qcb sel" onclick="this.classList.toggle('sel')"><div class="qbox"></div>Anlagefonds</div>
                      <div class="qcb" onclick="this.classList.toggle('sel')"><div class="qbox"></div>Hedgefonds / Alternative</div>
                      <div class="qcb" onclick="this.classList.toggle('sel')"><div class="qbox"></div>Derivate / Optionsscheine</div>
                      <div class="qcb" onclick="this.classList.toggle('sel')"><div class="qbox"></div>Zertifikate / Strukturierte</div>
                      <div class="qcb" onclick="this.classList.toggle('sel')"><div class="qbox"></div>Rohstoffanlagen</div>
                    </div>
                  </div>
                  <div class="qsec">
                    <div class="ql"><span class="qnum">2</span><span>Bewirtschaftungsform</span></div>
                    <div class="qopts">
                      <div class="qopt" onclick="sq(this,'q2')"><div class="qrad"></div><span class="qtxt">Bisher keine Anlagen getГғВӨtigt</span></div>
                      <div class="qopt" onclick="sq(this,'q2')"><div class="qrad"></div><span class="qtxt">In Eigenregie bewirtschaftet</span></div>
                      <div class="qopt sel" onclick="sq(this,'q2')"><div class="qrad"></div><span class="qtxt">Aktiv von Anlageberater unterstГғВјtzt</span></div>
                      <div class="qopt" onclick="sq(this,'q2')"><div class="qrad"></div><span class="qtxt">Im Rahmen einer VermГғВ¶gensverwaltung delegiert</span></div>
                    </div>
                  </div>
                  <div class="qsec">
                    <div class="ql"><span class="qnum">3</span><span>Erfahrungen mit Wertschriftenanlagen</span></div>
                    <div class="qopts">
                      <div class="qopt" onclick="sq(this,'q3')"><div class="qrad"></div><span class="qtxt">Keine Erfahrung</span></div>
                      <div class="qopt" onclick="sq(this,'q3')"><div class="qrad"></div><span class="qtxt">Wenig ГўвӮ¬вҖқ keine grossen KursrГғВјckgГғВӨnge erlebt</span></div>
                      <div class="qopt sel" onclick="sq(this,'q3')"><div class="qrad"></div><span class="qtxt">Grosse ГўвӮ¬вҖқ deutliche KursrГғВјckgГғВӨnge miterlebt</span></div>
                      <div class="qopt" onclick="sq(this,'q3')"><div class="qrad"></div><span class="qtxt">Sehr grosse ГўвӮ¬вҖқ spekulative Anlageformen gehandelt</span></div>
                    </div>
                  </div>
                  <div class="qsec" style="margin-bottom:0">
                    <div class="ql"><span class="qnum">4</span><span>JГғВӨhrliches Bruttoeinkommen</span></div>
                    <input class="qinp" value="CHF 380'000" style="margin-left:24px;width:calc(100% - 24px);margin-bottom:5px">
                    <div class="qcbs">
