      <div><label class="fl" style="font-size:9px">LiquiditГғВӨt</label><input class="fi" id="sc-liq" type="number" min="0" max="100" value="0" oninput="calcSCTotal()"></div>
      <div><label class="fl" style="font-size:9px">Alternative</label><input class="fi" id="sc-alt" type="number" min="0" max="100" value="0" oninput="calcSCTotal()"></div>
      <div style="display:flex;align-items:flex-end"><div id="sc-tot" style="padding:5px 8px;border:1px solid var(--b1);border-radius:var(--r);font-size:11px;font-weight:600;width:100%;text-align:center;color:var(--n6)">Total: 0%</div></div>
