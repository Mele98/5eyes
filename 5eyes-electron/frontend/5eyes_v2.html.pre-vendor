              <div class="wr"><div class="wn"><div class="wna">Cash / LiquiditГғВӨt</div><div class="wnd">Sichtguthaben UBS</div></div><div class="wa">CHF 210'000</div><div class="wt"><span class="tag tb">Beratung</span></div></div>
              <div class="wr"><div class="wn"><div class="wna">PE-Fonds Partners Group A</div><div class="wnd">Illiquid ГӮВ· 8 J.</div></div><div class="wa">CHF 168'000</div><div class="wt"><span class="tag tb">Beratung</span></div></div>
              <div style="display:flex;justify-content:space-between;padding:6px 0 0;border-top:1px solid var(--b1);margin-top:2px"><span style="font-size:11px;font-weight:600">Total BeratungsvermГғВ¶gen</span><span style="font-family:var(--f-d);font-size:15px;color:var(--pos)">CHF 2'848'000</span></div>
            </div>
            <div>
              <div style="font-size:9px;font-weight:600;letter-spacing:0.07em;text-transform:uppercase;color:var(--n4);margin-bottom:5px;padding-bottom:3px;border-bottom:1px solid var(--b1)">Anderes VermГғВ¶gen (holistischer ГғЕ“berblick)</div>
              <div class="wr"><div class="wn"><div class="wna">Eigenheim ZГғВјrich-Seefeld</div><div class="wnd">Marktwert</div></div><div class="wa">CHF 1'450'000</div><div class="wt"><span class="tag tn">Andere</span></div><button class="btn-ico e" onclick="om('m-edit-custom')" title="Bearbeiten">ГўЕ“ЕҪ</button></div>
              <div class="wr"><div class="wn"><div class="wna">BVG / Pensionskasse</div><div class="wnd">Gesperrt bis 2033</div></div><div class="wa">CHF 340'000</div><div class="wt"><span class="tag tn">Andere</span></div></div>
              <div class="wr"><div class="wn"><div class="wna">SГғВӨule 3a (2 Konten BEKB)</div><div class="wnd">Bezug ab 2027</div></div><div class="wa">CHF 112'000</div><div class="wt"><span class="tag tn">Andere</span></div></div>
              <div class="wr"><div class="wn"><div class="wna">Hypothek Eigenheim</div><div class="wnd">1.2% bis 2027</div></div><div class="wa" style="color:var(--neg)">ГўЛҶвҖҷCHF 856'000</div><div class="wt"><span class="tag tr2">Verbindl.</span></div><button class="btn-ico e" onclick="om('m-edit-hypo')" title="Bearbeiten">ГўЕ“ЕҪ</button></div>
